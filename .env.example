# Copy this file to .env and fill in your own API keys.
# Never commit the real .env file — it is gitignored.

# US Census Bureau (optional but recommended — improves reliability)
# Get key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# FRED — St. Louis Fed (rental vacancy rates)
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI (company news)
# Get key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# WalkScore (walk/transit/bike scores)
# Get key at: https://www.walkscore.com/professional/api.php
WALKSCORE_API_KEY=your_walkscore_api_key_here

# Google Places API (property ratings and reviews)
# Get key at: https://console.cloud.google.com → APIs & Services → Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# FBI Crime Data Explorer
# Get key at: https://api.usa.gov/crime/fbi/cde
FBI_API_KEY=your_fbi_api_key_here

# Intellipins (geocoding and parcel data)
# Get key at: https://intellipins.com
INTELLIPINS_KEY=your_intellipins_key_here

# Anthropic (Claude — pain point inference and outreach email generation)
# Get key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq (optional alternative LLM provider)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (optional alternative LLM provider)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
